# .env — credentials for running integration tests locally
# Copy this file to .env and fill in your values, then run:
#   npm run test:integration
#
# These variables are primarily used by integration tests.
# The MCP runtime can also use them as a bootstrap/fallback profile when no
# servers.json profile store exists yet.

# Required
SSH_HOST=192.168.1.100
SSH_USER=myuser

# Auth — use one of these two:
SSH_PASSWORD=mysecretpassword
# SSH_KEY_PATH=C:/Users/<username>/.ssh/id_rsa

# Optional (defaults to 22)
# SSH_PORT=22

# Optional runtime config overrides
# SSH_SERVERS_FILE=C:/Users/<username>/.ssh-mcp/servers.json
# SSH_POLICY_FILE=C:/Users/<username>/.ssh-mcp/policy.json
# SSH_AUDIT_FILE=C:/Users/<username>/.ssh-mcp/audit.log.jsonl
